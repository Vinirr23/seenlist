# Mesmas variáveis do apps/web/.env.local (URL + anon key do projeto).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Usuário de teste real (crie um se não tiver) — precisa logar de
# verdade pra RLS deixar passar qualquer coisa.
SUPABASE_TEST_EMAIL=
SUPABASE_TEST_PASSWORD=

# Opcional — só necessária pras Partes 2 e 5 (schema/policies).
# Supabase → Project Settings → Database → Connection string → URI.
# NUNCA COMMITAR ISSO — dá acesso direto ao Postgres.
SUPABASE_DB_URL=
